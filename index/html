<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CERBER OS | DATASET CERBER</title>
    <style>
        :root {
            --bg: #060606;
            --panel: #0c0c0c;
            --border: #1f1f1f;
            --text: #999;
            --text-bright: #ccc;
            --green: #33ff33;
            --red: #cc0000;
            --amber: #cc9900;
            --gold: #c9a84c;
            --font: 'JetBrains Mono', 'Courier New', monospace;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background: #000;
            color: var(--text);
            font-family: var(--font);
            height: 100vh;
            overflow: hidden;
            font-size: 12px;
            letter-spacing: 0.4px;
            user-select: none;
        }
        body.admin-theme { --gold: #c9a84c; }

        #login-screen {
            position: fixed; inset: 0; background: #020202; z-index: 3000;
            display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 35px;
            transition: opacity 0.4s, visibility 0.4s;
        }
        #login-screen.hidden { opacity:0; visibility:hidden; pointer-events:none; display:none; }
        #login-screen .logo-container { text-align:center; }
        #login-screen .logo-container img {
            width: 90px; height: 90px; border-radius: 50%; border: 1px solid #2a2a2a;
            padding: 10px; background: #0a0a0a; filter: grayscale(100%) contrast(1.3); margin-bottom: 16px;
        }
        #login-screen .logo-container h1 { font-weight:400; font-size:18px; letter-spacing:10px; color:#ddd; text-transform:uppercase; margin-bottom:4px; }
        #login-screen .logo-container p { font-size:9px; letter-spacing:4px; color:#555; text-transform:uppercase; }
        #login-screen .input-group { display:flex; flex-direction:column; gap:10px; width:320px; }
        #login-screen .input-field { position:relative; }
        #login-screen .input-field input {
            background:#0a0a0a; border:1px solid #222; color:#ccc; padding:15px 15px 7px 15px;
            font-family:var(--font); font-size:13px; letter-spacing:1px; outline:none; width:100%; transition:0.3s;
        }
        #login-screen .input-field input:focus { border-color:#555; }
        #login-screen .input-field label {
            position:absolute; left:15px; top:50%; transform:translateY(-50%);
            font-size:10px; letter-spacing:2px; color:#444; pointer-events:none; transition:0.2s; text-transform:uppercase;
        }
        #login-screen .input-field input:focus+label,
        #login-screen .input-field input:not(:placeholder-shown)+label { top:20%; font-size:7px; color:#666; }
        #login-screen button {
            background:transparent; color:#aaa; border:1px solid #333; padding:13px;
            font-family:var(--font); font-size:11px; letter-spacing:4px; cursor:pointer; transition:0.3s; text-transform:uppercase; margin-top:5px;
        }
        #login-screen button:hover { background:#111; color:#fff; border-color:#555; }
        #login-screen .error-msg { color:var(--red); font-size:10px; letter-spacing:1px; min-height:14px; text-align:center; }
        #login-screen .status-line { color:#333; font-size:9px; letter-spacing:2px; display:flex; align-items:center; gap:6px; }
        #login-screen .status-line .dot { width:4px; height:4px; background:#444; border-radius:50%; animation:pulse-dot 3s infinite; }
        @keyframes pulse-dot { 0%,100%{opacity:0.4;} 50%{opacity:1;} }

        #transition-overlay {
            position:fixed; inset:0; background:#000; z-index:2999; opacity:0; visibility:hidden; pointer-events:none;
            transition:opacity 0.2s; display:flex; flex-direction:column; justify-content:center; align-items:center;
        }
        #transition-overlay.active { opacity:1; visibility:visible; }
        #transition-overlay .scan-line { position:absolute; top:50%; width:100%; height:1px; background:rgba(255,255,255,0.4); transform:scaleX(0); transition:transform 0.5s; }
        #transition-overlay.active .scan-line { transform:scaleX(1); }
        #transition-overlay .loading-text { color:#444; font-size:10px; letter-spacing:5px; opacity:0; transition:opacity 0.3s 0.2s; text-transform:uppercase; margin-top:20px; }
        #transition-overlay.active .loading-text { opacity:1; }

        #main-os { display:none; width:100vw; height:100vh; grid-template-rows:50px 1fr 22px; grid-template-columns:230px 1fr; background:#080808; opacity:0; transition:opacity 0.6s; }
        #main-os.visible { opacity:1; display:grid; }

        .header { grid-column:1/-1; background:#040404; display:flex; align-items:center; padding:0 18px; gap:10px; border-bottom:1px solid #1a1a1a; z-index:20; }
        .header img { width:26px; height:26px; border-radius:50%; border:1px solid #333; filter:grayscale(100%); opacity:0.8; }
        .header .sys-name { font-size:14px; letter-spacing:5px; color:#ccc; text-transform:uppercase; }
        .header .sys-sub { font-size:8px; letter-spacing:2px; color:#444; margin-left:auto; text-transform:uppercase; }
        .header .admin-badge { color:var(--gold); font-size:7px; letter-spacing:2px; border:1px solid var(--gold); padding:2px 7px; display:none; }
        .header .search-wrap { position:relative; }
        .header .search-wrap input { background:#0a0a0a; border:1px solid #1f1f1f; color:#999; padding:5px 10px; font-family:var(--font); font-size:9px; letter-spacing:1px; outline:none; width:160px; transition:0.3s; }
        .header .search-wrap input:focus { border-color:#444; width:220px; }
        .search-results { position:absolute; top:100%; right:0; width:320px; max-height:200px; overflow-y:auto; background:#0a0a0a; border:1px solid #1f1f1f; display:none; z-index:30; }
        .search-results.show { display:block; }
        .search-results .sr-item { padding:7px 10px; font-size:9px; color:#777; cursor:pointer; border-bottom:1px solid #111; }
        .search-results .sr-item:hover { background:#111; color:#bbb; }
        .header .logout-btn { background:none; border:1px solid #2a2a2a; color:#666; padding:5px 12px; font-family:var(--font); font-size:8px; letter-spacing:2px; transition:0.3s; text-transform:uppercase; }
        .header .logout-btn:hover { border-color:var(--red); color:var(--red); }

        .sidebar { background:#040404; padding:8px 0; display:flex; flex-direction:column; gap:1px; border-right:1px solid #151515; overflow-y:auto; grid-row:2; }
        .sidebar .sidebar-section { font-size:7px; letter-spacing:3px; color:#333; padding:5px 18px; text-transform:uppercase; }
        .sidebar .sidebar-divider { border-top:1px solid #141414; margin:4px 14px; }
        .sidebar .nav-btn { background:none; border:none; color:#555; padding:9px 18px; text-align:left; cursor:pointer; font-family:var(--font); font-size:10px; letter-spacing:1.5px; transition:0.2s; position:relative; text-transform:uppercase; }
        .sidebar .nav-btn .nav-key { font-size:7px; color:#333; margin-right:6px; }
        .sidebar .nav-btn:hover { color:#999; background:#0a0a0a; }
        .sidebar .nav-btn.active { color:#ddd; background:#0d0d0d; }
        .sidebar .nav-btn.active::before { content:''; position:absolute; left:0; top:0; bottom:0; width:2px; background:#555; }
        .sidebar .nav-btn.admin-nav { color:#6a5030; display:none; }
        .sidebar .nav-btn.admin-nav:hover { color:var(--gold); background:#0d0a04; }
        .sidebar .nav-btn.leader-locked { color:#2a2a2a; cursor:pointer; }
        .sidebar .nav-lock-icon { margin-left:auto; font-size:8px; color:#3a2020; }

        .main-content { background:#0a0a0a; padding:22px; overflow-y:auto; grid-row:2; }
        .main-content::-webkit-scrollbar { width:3px; }
        .main-content::-webkit-scrollbar-track { background:#000; }
        .main-content::-webkit-scrollbar-thumb { background:#1a1a1a; }
        .tab-panel { display:none; animation:fadeTab 0.25s; }
        .tab-panel.active { display:block; }
        @keyframes fadeTab { from{opacity:0;transform:translateY(3px);} to{opacity:1;transform:translateY(0);} }

        .dash-hero { display:flex; align-items:center; gap:18px; margin-bottom:18px; padding:16px 20px; background:#0b0b0b; border:1px solid #1a1a1a; }
        .dash-hero img { width:42px; height:42px; border-radius:50%; border:1px solid #333; filter:grayscale(100%); opacity:0.8; flex-shrink:0; }
        .dash-hero-text h2 { font-size:16px; letter-spacing:6px; color:#ccc; font-weight:400; text-transform:uppercase; }
        .dash-hero-text .dh-version { font-size:8px; color:#555; letter-spacing:2px; margin-top:2px; }
        .dash-hero-text .dh-desc { font-size:8px; color:#444; letter-spacing:1.5px; margin-top:2px; }
        .dash-status-line { display:flex; align-items:center; gap:8px; margin-bottom:16px; font-size:9px; color:#666; letter-spacing:2px; }
        .dash-status-line .pulse { width:8px; height:8px; border-radius:50%; background:var(--green); box-shadow:0 0 12px rgba(51,255,51,0.6); animation:dashPulse 1.5s infinite; }
        @keyframes dashPulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:0.6;transform:scale(1.3);} }
        .dash-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
        .dash-card { background:#0b0b0b; border:1px solid #161616; padding:16px; transition:0.3s; cursor:pointer; }
        .dash-card:hover { border-color:#2a2a2a; background:#0e0e0e; }
        .dash-card .dc-num { font-size:32px; color:#ccc; letter-spacing:3px; font-weight:300; }
        .dash-card .dc-lbl { font-size:8px; letter-spacing:2px; color:#555; text-transform:uppercase; margin-top:4px; }
        .dash-mini-map { background:#060606; border:1px solid #1a1a1a; height:180px; position:relative; margin-bottom:16px; overflow:hidden; }
        .dash-mini-map .mm-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px); background-size:50px 50px; }
        .mm-dot { position:absolute; width:8px; height:8px; border-radius:50%; transform:translate(-50%,-50%); cursor:pointer; transition:0.3s; }
        .mm-dot.warehouse { background:#2a2a2a; border:1px solid #444; }
        .mm-dot.hq { background:var(--gold); border:1px solid #6a5030; width:10px; height:10px; animation:mmPulse 2s infinite; }
        @keyframes mmPulse { 0%,100%{box-shadow:0 0 4px rgba(201,168,76,0.3);} 50%{box-shadow:0 0 12px rgba(201,168,76,0.6);} }
        .mm-dot.partner { background:#1a3a1a; border:1px solid #3a6a3a; }
        .mm-dot.rival { background:#3a1010; border:1px solid #6a3030; }
        .mm-cursor-tip { position:absolute; background:#0a0a0a; border:1px solid #444; padding:6px 10px; font-size:8px; color:#bbb; pointer-events:none; display:none; z-index:20; white-space:nowrap; letter-spacing:1px; }

        .warehouse-gallery { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:14px; }
        .wh-gallery-item { background:#0b0b0b; border:1px solid #161616; overflow:hidden; cursor:pointer; transition:0.3s; position:relative; aspect-ratio:3/2; }
        .wh-gallery-item:hover { border-color:#333; }
        .wh-gallery-item img { width:100%; height:100%; object-fit:cover; filter:grayscale(100%) contrast(1.2); opacity:0.6; transition:0.3s; }
        .wh-gallery-item:hover img { opacity:0.9; filter:grayscale(70%) contrast(1.2); }
        .wh-gallery-item .wh-label { position:absolute; bottom:0; left:0; right:0; padding:6px 8px; background:rgba(0,0,0,0.85); font-size:7px; color:#999; letter-spacing:1px; text-align:center; }

        .dash-activity { display:flex; flex-direction:column; gap:4px; max-height:120px; overflow-y:auto; }
        .dash-activity .da-item { display:flex; align-items:center; gap:8px; padding:5px 0; border-bottom:1px solid #0f0f0f; font-size:8px; color:#777; }
        .dash-activity .da-time { color:#444; font-size:7px; min-width:40px; }

        .timeline { display:flex; flex-direction:column; gap:2px; position:relative; padding-left:20px; }
        .timeline::before { content:''; position:absolute; left:8px; top:0; bottom:0; width:1px; background:#1a1a1a; }
        .tl-item { display:flex; gap:10px; padding:8px 0; position:relative; }
        .tl-item::before { content:''; position:absolute; left:-16px; top:12px; width:8px; height:8px; border-radius:50%; background:#333; border:1px solid #444; }
        .tl-item.upcoming::before { background:var(--amber); border-color:#665020; }
        .tl-item.past::before { background:#1a3a1a; border-color:#2a5a2a; }
        .tl-date { font-size:8px; color:#555; min-width:70px; letter-spacing:1px; }
        .tl-text { font-size:9px; color:#888; }
        .tl-tag { font-size:7px; padding:1px 6px; border:1px solid #2a2a2a; color:#666; letter-spacing:1px; display:inline-block; margin-left:4px; }

        .card { background:#0b0b0b; border:1px solid #161616; padding:18px; margin-bottom:10px; transition:0.25s; }
        .card:hover { border-color:#222; }
        .card h3 { color:#ccc; font-size:11px; letter-spacing:2px; margin-bottom:10px; text-transform:uppercase; font-weight:400; border-bottom:1px solid #151515; padding-bottom:8px; }
        .card p { color:#888; line-height:1.7; font-size:10px; margin-bottom:2px; }
        .card .lbl { color:#555; letter-spacing:1px; font-size:9px; text-transform:uppercase; }
        .card .val { color:#bbb; }

        table { width:100%; border-collapse:collapse; font-size:9px; }
        table th { background:#0c0c0c; color:#666; padding:8px 12px; text-align:left; letter-spacing:1.5px; font-weight:400; border-bottom:1px solid #1a1a1a; font-size:8px; text-transform:uppercase; }
        table td { padding:7px 12px; border-bottom:1px solid #111; color:#999; cursor:pointer; }
        table tr:hover td { background:#0d0d0d; }

        .status-dot { display:inline-block; width:6px; height:6px; border-radius:50%; margin-right:4px; }
        .s-active { background:var(--green); box-shadow:0 0 4px rgba(51,255,51,0.3); }
        .s-warn { background:var(--amber); box-shadow:0 0 4px rgba(204,153,0,0.3); }
        .s-off { background:var(--red); }

        .status-bar { grid-column:1/-1; background:#020202; border-top:1px solid #151515; display:flex; align-items:center; padding:0 10px; font-size:7px; letter-spacing:1.5px; color:#333; gap:12px; text-transform:uppercase; }
        .status-bar .live-dot { width:4px; height:4px; background:var(--green); border-radius:50%; animation:pulse 2.5s infinite; }
        @keyframes pulse { 0%,100%{opacity:0.3;} 50%{opacity:1;} }

        /* Остальные стили (полные) */
        .dossier-btn { background:#0d0d0d; border:1px solid #1f1f1f; color:#bbb; padding:10px 16px; cursor:pointer; font-family:var(--font); font-size:9px; letter-spacing:2px; text-transform:uppercase; transition:0.3s; margin-right:6px; margin-bottom:6px; }
        .dossier-btn:hover { background:#1a1a1a; border-color:#333; }
        .client-card { background:#0b0b0b; border:1px solid #161616; padding:14px; margin-bottom:6px; cursor:pointer; transition:0.3s; }
        .client-card:hover { border-color:#2a2a2a; background:#0e0e0e; }
        .client-card .cc-name { font-size:10px; color:#bbb; letter-spacing:2px; }
        .client-card .cc-id { font-size:7px; color:#555; margin-bottom:4px; }
        .client-card .cc-stat { font-size:7px; color:#666; display:flex; gap:8px; }
        .inv-bar-wrap { flex:1; height:6px; background:#111; border:1px solid #1a1a1a; }
        .inv-bar { height:100%; background:#333; }
        .inv-bar.high { background:#555; }
        .inv-bar.low { background:var(--amber); }

        .protocol-card { background:#0b0b0b; border:1px solid #161616; padding:20px; margin-bottom:10px; cursor:pointer; transition:0.3s; }
        .protocol-card:hover { border-color:#2a2a2a; background:#0e0e0e; }
        .protocol-card .pc-stamp { font-size:8px; color:var(--red); letter-spacing:2px; border:1px solid var(--red); padding:3px 8px; text-transform:uppercase; display:inline-block; margin-right:8px; }
        .protocol-card .pc-date { font-size:8px; color:#555; letter-spacing:1px; display:inline-block; }
        .protocol-card .pc-title { font-size:10px; color:#ccc; letter-spacing:2px; text-transform:uppercase; margin-top:6px; }
        .protocol-card .pc-preview { font-size:8px; color:#666; line-height:1.6; margin-top:4px; }

        .comm-entry { background:#0b0b0b; border:1px solid #161616; padding:14px; margin-bottom:8px; }
        .comm-entry .comm-dot { width:8px; height:8px; border-radius:50%; display:inline-block; margin-right:6px; }
        .comm-entry .comm-dot.urgent { background:var(--red); box-shadow:0 0 6px rgba(204,0,0,0.4); }
        .comm-entry .comm-dot.routine { background:#444; }
        .comm-entry .comm-from { font-size:8px; color:#888; letter-spacing:1.5px; text-transform:uppercase; display:inline-block; }
        .comm-entry .comm-date { font-size:7px; color:#555; float:right; }
        .comm-entry .comm-text { font-size:9px; color:#999; line-height:1.6; margin-top:4px; }
        .comm-entry .comm-response { margin-top:8px; padding:8px 12px; background:#0d0d0d; border-left:2px solid #333; font-size:8px; color:#777; }

        .folder-block { margin-bottom:5px; }
        .folder-head { padding:8px 12px; background:#0d0d0d; border:1px solid #181818; cursor:pointer; font-size:9px; letter-spacing:2px; color:#888; display:flex; align-items:center; gap:7px; transition:0.2s; text-transform:uppercase; }
        .folder-head:hover { background:#111; color:#bbb; }
        .folder-head .arr { transition:0.3s; color:#555; }
        .folder-block.open .arr { transform:rotate(90deg); }
        .folder-body { max-height:0; overflow:hidden; transition:max-height 0.35s; }
        .folder-block.open .folder-body { max-height:320px; overflow-y:auto; }
        .file-item { display:flex; align-items:center; gap:7px; padding:6px 12px 6px 24px; cursor:pointer; font-size:8px; color:#777; border-bottom:1px solid #0f0f0f; }
        .file-item:hover { background:#0d0d0d; color:#bbb; }
        .file-item .fd { width:3px; height:3px; background:#333; border-radius:50%; flex-shrink:0; }
        .file-item.secret-file { color:#4a3030; }
        .file-item.secret-file .fd { background:#4a3030; }
        .upload-zone { border:1px dashed #1a1a1a; padding:14px; text-align:center; cursor:pointer; transition:0.3s; margin-top:8px; color:#444; font-size:8px; letter-spacing:2px; text-transform:uppercase; }
        .upload-zone:hover { border-color:#333; color:#666; }
        .upload-zone input { display:none; }
        .upload-zone.locked { cursor:not-allowed; color:#2a2a2a; border-color:#111; }

        .map-full { position:relative; width:100%; height:420px; background:#040404; border:1px solid #1a1a1a; overflow:hidden; margin-bottom:14px; }
        .map-full .mf-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size:50px 50px; }
        .map-point-full { position:absolute; width:14px; height:14px; border-radius:50%; transform:translate(-50%,-50%); cursor:pointer; transition:0.3s; z-index:2; }
        .map-point-full.warehouse { background:#2a2a2a; border:2px solid #555; }
        .map-point-full.hq { background:var(--gold); border:2px solid #8a7040; width:20px; height:20px; }
        .map-point-full.partner { background:#1a3a1a; border:2px solid #3a7a3a; }
        .map-point-full.rival { background:#3a1010; border:2px solid #7a4040; }
        .map-label-full { position:absolute; font-size:8px; color:#666; letter-spacing:2px; transform:translate(-50%,12px); pointer-events:none; white-space:nowrap; text-transform:uppercase; }
        .map-cursor-tip { position:absolute; background:#0a0a0a; border:1px solid #555; padding:8px 14px; font-size:9px; color:#ccc; pointer-events:none; display:none; z-index:20; }
        .map-info-panel { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
        .map-info-item { background:#0b0b0b; border:1px solid #161616; padding:12px 14px; display:flex; align-items:flex-start; gap:10px; }
        .map-info-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; margin-top:2px; }
        .map-info-dot.warehouse { background:#2a2a2a; border:2px solid #555; }
        .map-info-dot.hq { background:var(--gold); border:2px solid #8a7040; }
        .map-info-dot.partner { background:#1a3a1a; border:2px solid #3a7a3a; }
        .map-info-dot.rival { background:#3a1010; border:2px solid #7a4040; }

        .log-item { font-size:8px; padding:3px 0; border-bottom:1px solid #0f0f0f; color:#555; }
        .log-item .lt { color:#333; margin-right:6px; }
        .log-item.ghost { color:#2a2020; font-style:italic; }

        .adm-block { background:#0b0a06; border:1px solid #1f1808; padding:14px; margin-bottom:8px; }
        .adm-block h4 { color:var(--gold); font-size:9px; letter-spacing:2px; margin:0 0 7px; text-transform:uppercase; font-weight:400; }
        .adm-inp,.adm-ta { background:#0a0a0a; border:1px solid #1f1f1f; color:#ccc; padding:6px 9px; font-family:var(--font); font-size:8px; letter-spacing:1px; outline:none; width:100%; margin:2px 0 7px; transition:0.3s; }
        .adm-inp:focus,.adm-ta:focus { border-color:#4a3820; }
        .adm-ta { resize:vertical; min-height:50px; }
        .adm-btn { background:transparent; color:#8a7040; border:1px solid #2a2010; padding:6px 14px; cursor:pointer; font-family:var(--font); font-size:7px; letter-spacing:2px; transition:0.3s; text-transform:uppercase; margin-right:4px; margin-top:2px; }
        .adm-btn:hover { background:#0f0d08; color:var(--gold); border-color:#4a3820; }
        .adm-btn.danger { color:#664444; border-color:#2a1010; }
        .adm-btn.danger:hover { background:#0d0606; color:var(--red); border-color:#4a2020; }

        .dos-photo-select { display:flex; gap:6px; align-items:center; margin-bottom:4px; }
        .dos-photo-select select { background:#0a0a0a; border:1px solid #1f1f1f; color:#ccc; padding:3px 6px; font-family:var(--font); font-size:7px; outline:none; flex:1; }
        .dos-photo-select .current { font-size:7px; color:#555; }

