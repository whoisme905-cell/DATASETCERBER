                <div class="adm-block"><h4>Заметки администратора</h4><textarea class="adm-ta" id="adm-notes" rows="3">${sys.adminNotes||''}</textarea><button class="adm-btn" onclick="admSaveNotes()">Сохранить</button></div>`;
        }

        function admWH() { sys.warehouses.forEach((w, i) => { const s = document.getElementById('aws-' + i); if (s) w.st = s.value; const c = document.getElementById('awc-' + i); if (c) w.cur = Math.min(parseInt(c.value) || 0, w.cap); const p = document.getElementById('awp-' + i); if (p && p.value) w.img = p.value; });
            saveData();
            switchTab('admin');
            switchTab('warehouses');
            switchTab('dashboard');
            xlog('Склады обновлены'); }

        function admDossiers() {
            ['marshall', 'ace', 'knox'].forEach(id => {
                const cp = sys.combat[id] || {};
                cp.style = document.getElementById('adm-style-' + id)?.value || cp.style;
                cp.weapon = document.getElementById('adm-weapon-' + id)?.value || cp.weapon;
                cp.sec = document.getElementById('adm-sec-' + id)?.value || cp.sec;
                cp.exp = document.getElementById('adm-exp-' + id)?.value || cp.exp;
                cp.acc = parseInt(document.getElementById('adm-acc-' + id)?.value) || cp.acc;
                cp.agg = parseInt(document.getElementById('adm-agg-' + id)?.value) || cp.agg;
                cp.def = parseInt(document.getElementById('adm-def-' + id)?.value) || cp.def;
                cp.stl = parseInt(document.getElementById('adm-stl-' + id)?.value) || cp.stl;
                sys.combat[id] = cp;
                const imgs = [];
                for (let i = 0; i < 3; i++) { const sel = document.getElementById('adm-dimg-' + id + '-' + i);
                    imgs.push(sel?.value || (sys.dossierImgs[id]?.[i] || svgi(id.toUpperCase()))); }
                sys.dossierImgs[id] = imgs;
            });
            saveData();
            switchTab('admin');
            xlog('Досье обновлены'); }

        function admDL() { sys.deals.forEach((d, i) => { const s = document.getElementById('ads-' + i); if (s) d.st = s.value; });
            saveData();
            switchTab('admin');
            switchTab('deals'); }
        function admDelDL(i) { sys.deals.splice(i, 1);
            saveData();
            switchTab('admin');
            switchTab('deals'); }
        function admAddDL() { sys.deals.push({ date: new Date().toLocaleDateString('ru-RU'), client: 'НОВЫЙ', item: 'Товар', amt: '$0', st: 'pending' });
            saveData();
            switchTab('admin');
            switchTab('deals'); }
        function admSaveNotes() { sys.adminNotes = document.getElementById('adm-notes')?.value || '';
            saveData(); }

        function openWH(id) { const w = sys.warehouses.find(x => x.id === id); if (!w) return; const sm = { active: 's-active', warning: 's-warn', inactive: 's-off' },
                lm = { active: 'Активен', warning: 'Проверка', inactive: 'Закрыт' };
            document.getElementById('popup-title').textContent = 'Склад #' + w.id;
            document.getElementById('popup-body').innerHTML = `<div class="card"><h3>Информация</h3><p><span class="lbl">Статус:</span> <span class="val"><span class="status-dot ${sm[w.st]}"></span>${lm[w.st]}</span></p><p><span class="lbl">Загрузка:</span> <span class="val">${w.cur}/${w.cap}</span></p><img src="${w.img}" style="width:100%;margin-top:10px;border:1px solid #1a1a1a;filter:grayscale(100%) contrast(1.1);" onerror="this.style.display='none'"></div>`;
            document.getElementById('popup-overlay').classList.add('active');
            sndOpen(); }
        function openDL(i) { const d = sys.deals[i]; if (!d) return;
            document.getElementById('popup-title').textContent = 'Сделка — ' + d.item;
            document.getElementById('popup-body').innerHTML = `<div class="card"><h3>Детали</h3><p><span class="lbl">Клиент:</span> <span class="val">${d.client}</span></p><p><span class="lbl">Сумма:</span> <span class="val">${d.amt}</span></p></div>`;
            document.getElementById('popup-overlay').classList.add('active');
            sndOpen(); }

        function exportTbl(type) { let d = type === 'warehouses' ? 'Объект,Статус,Загрузка\n' + sys.warehouses.map(w => `Склад #${w.id},${w.st},${w.cur}/${w.cap}`).join('\n') : 'Дата,Клиент,Товар,Сумма,Статус\n' + sys.deals.map(d => `${d.date},${d.client},${d.item},${d.amt},${d.st}`).join('\n'); const w = window.open('', '_blank', 'width=600,height=400');
            w.document.write('<pre style="background:#000;color:#ccc;padding:20px;font-family:monospace;">' + d + '</pre>');
            w.document.close(); }

        function handleFiles(e) { if (!isAdmin) return; const files = e.target.files; if (!files.length) return; const map = { 'image': 'im', 'video': 'vid', 'audio': 'aud', 'application/pdf': 'pdf' }; for (const f of files) { const cat = Object.keys(map).find(k => f.type.startsWith(k)); if (!cat) continue; const fk = map[cat],
                    url = URL.createObjectURL(f);
                uploadedFiles.push({ name: f.name, type: f.type, size: f.size, url, cat }); const fc = document.getElementById('fc-' + fk); if (!fc) continue; const row = document.createElement('div');
                row.className = 'file-item';
                row.innerHTML = `<span class="fd"></span><span>${f.name}</span>`;
                row.addEventListener('click', () => openFileWin(url, f.name, f.type));
                fc.appendChild(row); const fb = document.getElementById('fb-' + fk); if (fb && !fb.classList.contains('open')) fb.classList.add('open');
                document.getElementById('cnt-' + fk).textContent = fc.children.length;
                xlog('Файл загружен: ' + f.name); }
            document.getElementById('file-input').value = ''; if (document.getElementById('panel-admin')?.classList.contains('active')) switchTab('admin'); }

        function openSecretFolder() { if (secretUnlocked) { document.getElementById('fb-sec').classList.toggle('open'); return; }
            document.getElementById('popup-title').textContent = 'Засекреченные файлы';
            document.getElementById('popup-body').innerHTML = `<div class="password-dialog"><p style="color:#888;font-size:9px;">Пароль доступа</p><input type="password" id="secret-files-pw" placeholder="Пароль"><button onclick="unlockSecret()">Разблокировать</button><p class="pw-error" id="secret-files-err"></p></div>`;
            document.getElementById('popup-overlay').classList.add('active'); }
        function unlockSecret() { if (document.getElementById('secret-files-pw')?.value.trim() === SECRET_FILES_PW) { secretUnlocked = true;
                closePopup();
                showSecretFiles();
                document.getElementById('fb-sec').classList.add('open');
                sndSecret(); } else { document.getElementById('secret-files-err').textContent = 'Неверный пароль'; } }
        function showSecretFiles() { const fc = document.getElementById('fc-sec'); if (!fc) return; const docs = sys.secretDocs || getDefaultData().secretDocs;
            fc.innerHTML = docs.map(d => `<div class="file-item secret-file" onclick="openSecretDoc('${d.name.replace(/'/g, "\\'")}')"><span class="fd"></span><span>${d.name}</span></div>`).join(''); }
        function openSecretDoc(name) { const docs = sys.secretDocs || getDefaultData().secretDocs; const doc = docs.find(d => d.name === name); if (!doc) return;
            filesOpenedCount++;
            document.getElementById('files-opened-count').textContent = filesOpenedCount;
            sndOpen();
            document.getElementById('popup-title').textContent = doc.name;
            document.getElementById('popup-body').innerHTML = `<div class="card"><h3>${doc.name}</h3><p style="color:var(--red);font-size:8px;">ГРИФ: СЕКРЕТНО</p><p><span class="lbl">Описание:</span> <span class="val">${doc.desc}</span></p></div>`;
            document.getElementById('popup-overlay').classList.add('active'); }

        function openDos(id) {
            const data = { marshall: { title: 'Маршалл Кинн', cid: 'CER-001', role: 'Руководитель / Стратег', appt: 'Ноябрь 2020', st: 'Активен', clr: '5' }, ace: { title: 'Эйс Блэквуд', cid: 'CER-002', role: 'Силовик / Охрана', appt: 'Ноябрь 2020', st: 'Активен', clr: '4' }, knox: { title: 'Нокс Вестерн', cid: 'CER-003', role: 'Кибероперации', appt: 'Ноябрь 2020', st: 'Активен', clr: '4' } } [id];
            if (!data) return;
            const notes = sys.notes[id] || '',
                cp = sys.combat[id] || {},
                imgs = sys.dossierImgs[id] || [svgi(id.toUpperCase()), svgi('ФОТО 2'), svgi('ФОТО 3')],
                bc = v => v > 80 ? 'high' : '';
            const bars = ['acc', 'agg', 'def', 'stl'].map(s => { const v = cp[s] || 0; const lbs = { acc: 'Меткость', agg: 'Агрессия', def: 'Защита', stl: 'Скрытность' }; return `<div class="combat-stat"><span class="cs-label">${lbs[s]}</span><div class="cs-bar-wrap"><div class="cs-bar ${bc(v)}" style="width:${v}%;"></div></div><span style="font-size:7px;color:#666;">${v}%</span></div>`; }).join('');
            document.getElementById('popup-title').textContent = 'Досье — ' + data.title;
            document.getElementById('popup-body').innerHTML = `<div class="dos-grid"><div class="dos-photos">${imgs.map(s => `<img src="${s}" onclick="openFS(this.src)" onerror="this.style.display='none'">`).join('')}</div><div><h3 style="color:#ccc;font-size:11px;letter-spacing:2px;margin-bottom:8px;">${data.cid}</h3><p><span class="lbl">Роль:</span> <span class="val">${data.role}</span></p><p style="margin-top:8px;"><span class="lbl">Заметки:</span> <span class="val">${notes}</span></p></div></div><div class="card" style="margin-top:10px;"><h3>Боевой профиль</h3><p><span class="lbl">Стиль:</span> <span class="val">${cp.style||'—'}</span></p><p><span class="lbl">Оружие:</span> <span class="val">${cp.weapon||'—'} / ${cp.sec||'—'}</span></p><p><span class="lbl">Опыт:</span> <span class="val">${cp.exp||'—'}</span></p><div style="margin-top:10px;">${bars}</div></div><div class="dos-main-img"><img src="${imgs[0]}" onclick="openFS(this.src)" onerror="this.style.display='none'"></div>`;
            document.getElementById('popup-overlay').classList.add('active');
            sndOpen();
        }

        function openFileWin(url, name, type) { filesOpenedCount++;
            document.getElementById('files-opened-count').textContent = filesOpenedCount;
            sndOpen();
            document.getElementById('popup-title').textContent = name; const body = document.getElementById('popup-body');
            body.innerHTML = '<div class="file-view"></div>'; const fv = body.querySelector('.file-view'); if (type.startsWith('image/')) { const img = document.createElement('img');
                img.src = url;
                img.style.cursor = 'pointer';
                img.onclick = () => openFS(url);
                fv.appendChild(img); } else if (type.startsWith('video/')) { const v = document.createElement('video');
                v.src = url;
                v.controls = true;
                v.autoplay = true;
                fv.appendChild(v); } else if (type.startsWith('audio/')) { const w = document.createElement('div');
                w.style.cssText = 'text-align:center;'; const l = document.createElement('p');
                l.textContent = name;
                l.style.cssText = 'color:#999;font-size:10px;'; const a = document.createElement('audio');
                a.src = url;
                a.controls = true;
                a.autoplay = true;
                a.style.width = '340px';
                w.appendChild(l);
                w.appendChild(a);
                fv.appendChild(w); } else if (type === 'application/pdf') { const ifr = document.createElement('iframe');
                ifr.src = url;
                fv.appendChild(ifr); }
            document.getElementById('popup-overlay').classList.add('active'); }

        function closePopup() { document.getElementById('popup-body').querySelectorAll('video, audio').forEach(el => { el.pause();
                el.currentTime = 0; });
            document.getElementById('popup-overlay').classList.remove('active'); }
        document.getElementById('popup-overlay').addEventListener('click', function(e) { if (e.target === this) closePopup(); });
        function openFS(src) { document.getElementById('fs-img-src').src = src;
            document.getElementById('fs-img').classList.add('active'); }

        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { if (document.getElementById('popup-overlay').classList.contains('active')) closePopup(); if (document.getElementById('fs-img').classList.contains('active')) document.getElementById('fs-img').classList.remove('active'); } if (e.ctrlKey && e.key === 'l') { e.preventDefault();
                logout(); } if (!e.ctrlKey && !e.altKey && !e.metaKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') { const tm = { '1': 'dashboard', '2': 'dossiers', '3': 'warehouses', '4': 'deals', '5': 'clients', '6': 'files', '7': 'calendar', '8': 'map' }; if (tm[e.key]) { e.preventDefault();
                    switchTab(tm[e.key]); } } });

        xlog('Система загружена');
        window._logs = window._logs || [];
    </script>
</body>
</html>
